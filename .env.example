# ============================================================
# Fredy AI Agent Platform — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# Single source of truth for all services (agent, importer, eval,
# docker-compose). Service READMEs document which variables apply.
# ============================================================

# ── LLM ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=
# OPENAI_BASE_URL=                 # for Azure OpenAI or self-hosted gateways
GEMINI_API_KEY=

# Fallback model used when a request does not pin a model
LLM_FALLBACK_MODEL=claude-sonnet-4-5-20250929
# Max output tokens per provider
ANTHROPIC_MAX_TOKENS=4096
OPENAI_MAX_TOKENS=4096
GEMINI_MAX_TOKENS=4096

# ── Keycloak ─────────────────────────────────────────────────
KEYCLOAK_ADMIN_PASSWORD=change-me
KEYCLOAK_OPENWEBUI_SECRET=change-me
# Enable JWT auth on the agent by setting the JWKS URL (issuer then required)
# KEYCLOAK_JWKS_URL=http://keycloak:8080/realms/fredy/protocol/openid-connect/certs
# KEYCLOAK_ISSUER=http://keycloak:8080/realms/fredy
KEYCLOAK_AUDIENCE=fredy-agent

# ── Agent Service ────────────────────────────────────────────
PORT=8001
LOG_LEVEL=info
SERVICE_NAME=fredy-agent
PROJECT_ENV=development
# Static API key used in dev mode (no Keycloak). Alternatively set
# AGENT_ALLOW_ANONYMOUS=true for fully unauthenticated local dev.
AGENT_API_KEY=change-me
# AGENT_ALLOW_ANONYMOUS=false
# Role → tool allowlist (JSON); empty means all tools for all roles
# ROLE_TOOL_CONFIG={"admin":["vector_search"],"user":["vector_search"]}
# Fastify trustProxy: false | true | CIDR/IP allow-list
# TRUST_PROXY=false

# Rate limiting (per JWT subject when Keycloak is on, else per client IP)
RATE_LIMIT_RPM=60
RATE_LIMIT_BURST=10

# ── Retrieval / RAG ──────────────────────────────────────────
RAG_DEFAULT_RETRIEVAL_LIMIT=5
# Cosine cutoff — embedding-model dependent, recalibrate on model switch
RAG_SCORE_THRESHOLD=0.7
# Context budget in tokens (~4 chars/token), trimmed at chunk boundaries
RAG_TOKEN_BUDGET=3200
# Conversation-history budget; oldest turns dropped first
RAG_HISTORY_TOKEN_BUDGET=4000
# Condense follow-up questions into standalone retrieval queries (1 LLM call).
# Keep off until golden-set evals exist to measure the effect.
RAG_QUERY_REWRITE=false
# Resolve chunk table + embedding settings from the importer's rag_profiles
# registry instead of the env vars below
# RAG_PROFILE=

# ── Reranking (optional) ─────────────────────────────────────
# none | cohere | voyage — RERANK_API_KEY required when not "none"
RERANKER=none
# RERANK_API_KEY=
# RERANK_MODEL=                    # default: rerank-v3.5 (cohere) / rerank-2.5 (voyage)
RERANK_TOP_N=10
RERANK_THRESHOLD=0.0

# ── Embeddings ───────────────────────────────────────────────
# Provider: openai | voyage
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_TIMEOUT_MS=15000
# Provider-specific overrides (fall back to the shared values above)
# EMBEDDING_OPENAI_API_KEY=
# EMBEDDING_OPENAI_MODEL=text-embedding-3-small
# EMBEDDING_VOYAGE_API_KEY=
# EMBEDDING_VOYAGE_MODEL=voyage-3-lite
# Must match the VECTOR(n) column dimension in infrastructure/postgres/init.sql
EMBEDDING_DIMENSIONS=1536

# ── Confluence (optional) ────────────────────────────────────
CONFLUENCE_BASE_URL=
CONFLUENCE_USERNAME=
CONFLUENCE_API_TOKEN=
CONFLUENCE_SPACES=
CONFLUENCE_INCLUDE_LABELS=
CONFLUENCE_EXCLUDE_LABELS=ignore,draft,archived

# ── Jira agent (optional) ────────────────────────────────────
# Autonomous ticket agent (services/jira-agent). All five values below are
# required for the service to boot; without them the container exits at start.
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
# accountId of the dedicated Jira account the agent acts as (Automation assigns
# new tickets to it). Find it via /rest/api/3/myself with the agent credentials.
JIRA_AGENT_ACCOUNT_ID=
# Override the derived reconcile JQL (default: unprocessed tickets assigned to
# the agent account in JIRA_PROJECT_KEY)
# JIRA_POLL_JQL=
JIRA_POLL_INTERVAL_MS=60000
# Unset = webhook endpoint disabled; the poller is the only trigger
# JIRA_WEBHOOK_SECRET=
# Transition names the agent may use (allow-list, case-insensitive)
JIRA_TRANSITION_RESOLVE=Done
JIRA_TRANSITION_WAITING=Waiting for customer
# pgvector table for the semantic ticket cache
TICKET_CACHE_TABLE=jira_ticket_cache

# ── PostgreSQL / pgvector ────────────────────────────────────
POSTGRES_DB=fredy
POSTGRES_USER=fredy
POSTGRES_PASSWORD=change-me
# Shared connection string for agent, confluence-importer and eval.
# Host is the compose service name; use localhost:5432 when running outside Docker.
DATABASE_URL=postgresql://fredy:change-me@postgres:5432/fredy
# Table holding the RAG chunks (env fallback when no RAG_PROFILE)
CHUNKS_TABLE=chunks

# ── Observability ────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
# Opt-in: capture prompt and completion content as span events. PII-sensitive.
OTEL_GENAI_CAPTURE_CONTENT=false

# ── Importer / Miscellaneous ─────────────────────────────────
VERBOSE=false
SYNC_CRON=0 */6 * * *
SYNC_FULL_ON_START=false
LOCAL_FILES_ENABLED=false
LOCAL_FILES_EXTENSIONS=.md,.txt,.html
CHUNK_MAX_TOKENS=800
CHUNK_OVERLAP_TOKENS=100
