{
  "name": "@fredy/eval",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc",
    "dev": "tsx --env-file=../../.env src/index.ts",
    "eval": "tsx --env-file=../../.env src/index.ts",
    "generate-dataset": "tsx --env-file=../../.env src/generator/cli.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.0",
    "@qdrant/js-client-rest": "^1.9.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.0.18"
  }
}
