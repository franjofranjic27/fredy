# Service-local example environment for @fredy/agent.
# Copy to ../../.env (repo root) or merge with the existing root .env.

# === Process ===
PORT=8001
LOG_LEVEL=info
SERVICE_NAME=fredy-agent
PROJECT_ENV=development

# === LLM providers ===
LLM_FALLBACK_MODEL=claude-sonnet-4-5-20250929
ANTHROPIC_API_KEY=
ANTHROPIC_MAX_TOKENS=4096
OPENAI_API_KEY=
# OPENAI_BASE_URL=                 # for Azure OpenAI or self-hosted gateways
OPENAI_MAX_TOKENS=4096
GEMINI_API_KEY=
GEMINI_MAX_TOKENS=4096
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
# OLLAMA_MODELS=llama3.2,mistral   # comma-separated allowlist

# === Embedding (used by vector_search) ===
EMBEDDING_PROVIDER=openai
EMBEDDING_OPENAI_API_KEY=
EMBEDDING_OPENAI_MODEL=text-embedding-3-small
# EMBEDDING_VOYAGE_API_KEY=
# EMBEDDING_VOYAGE_MODEL=voyage-3-lite

# === Qdrant (vector store) ===
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=confluence-pages

# === Retrieval / prompt budget ===
RAG_DEFAULT_RETRIEVAL_LIMIT=5
RAG_SCORE_THRESHOLD=0.7
RAG_TOKEN_BUDGET=3200

# === Session ===
SESSION_STORE_TYPE=memory
REDIS_URL=redis://localhost:6379
SESSION_TTL_MS=1800000

# === Auth ===
AGENT_API_KEY=
# KEYCLOAK_JWKS_URL=http://keycloak:8080/realms/fredy/protocol/openid-connect/certs
# KEYCLOAK_ISSUER=http://keycloak:8080/realms/fredy
KEYCLOAK_AUDIENCE=fredy-agent
# ROLE_TOOL_CONFIG={"admin":["vector_search","fetch_url","get_knowledge_base_stats"],"user":["vector_search","get_knowledge_base_stats"]}

# === Rate limit ===
RATE_LIMIT_RPM=60
RATE_LIMIT_BURST=10

# === Observability ===
# Set to forward traces to Jaeger / Tempo / any OTLP-HTTP collector.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Opt-in: capture prompt and completion content as span events. PII-sensitive.
OTEL_GENAI_CAPTURE_CONTENT=false
