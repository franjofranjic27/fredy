{
  "name": "@fredy/jira-agent",
  "version": "0.1.0",
  "description": "Fredy Jira agent service: autonomous ticket triage worker with webhook + polling triggers",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "start": "node --env-file=../../.env dist/main.js",
    "dev": "tsc -p tsconfig.build.json --watch & node --watch --env-file=../../.env dist/main.js",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src"
  },
  "keywords": ["ai", "agent", "jira", "fastify", "langgraph", "opentelemetry"],
  "packageManager": "pnpm@10.28.2",
  "dependencies": {
    "@fredy/agent-core": "workspace:*",
    "@langchain/core": "^1.2.1",
    "@langchain/langgraph": "^1.4.7",
    "@opentelemetry/api": "^1.9.0",
    "fastify": "^5.9.0",
    "pg": "^8.13.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.1.9"
  }
}
